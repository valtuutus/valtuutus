<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>$(NetLibVersion);</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Description>Valtuutus relational db data abstractions; $(Description)</Description>
        <PackageTags>$(PackageTags);db</PackageTags>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\Valtuutus.Data\Valtuutus.Data.csproj" />
    </ItemGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
            <_Parameter1>Valtuutus.Data.Db.Tests</_Parameter1>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
            <!-- Lets a relational provider's DI extension (e.g. AddPostgres) new up the internal
                 BatchedPhysicalExecutor directly, the same way Valtuutus.Core exposes its V2
                 internals to Valtuutus.Data.Db itself. -->
            <_Parameter1>Valtuutus.Data.Postgres</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>

</Project>
